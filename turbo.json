{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", ".expo/**", "dist/**", "lib/**", "out/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "@pokington/mobile#dev": {
      "dependsOn": [
        "@pokington/config#build",
        "@pokington/network#build",
        "@pokington/ui#build",
        "@pokington/engine#build",
        "@pokington/shared#build"
      ],
      "cache": false,
      "persistent": true
    },
    "party": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    }
  }
}
