{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@pokington/ui": ["packages/ui/src/index.ts"],
      "@pokington/ui/*": ["packages/ui/src/*"],
      "@pokington/network": ["packages/network/src/index.ts"],
      "@pokington/network/*": ["packages/network/src/*"],
      "@pokington/config": ["packages/config/src/index.ts"],
      "@pokington/config/*": ["packages/config/src/*"],
      "@pokington/engine": ["packages/engine/dist/index"],
      "@pokington/shared": ["packages/shared/dist/index"]
    }
  }
}
